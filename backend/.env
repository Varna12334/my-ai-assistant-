# 1. Remove the .env file from Git's tracking
git rm --cached backend/.env

# 2. Add .env to your .gitignore (if it's not already there)
echo ".env" >> .gitignore
echo "backend/.env" >> .gitignore

# 3. Commit the change
git add .gitignore
git commit -m "Security fix: Remove .env from repository"
git push origin main
